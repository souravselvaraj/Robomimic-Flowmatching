{
 "algo_name": "flow_matching",
 "experiment": {
  "name": "fm_transformer_square_image_seed3",
  "validate": true,
  "logging": {
   "terminal_output_to_txt": true,
   "log_tb": true,
   "log_wandb": false
  },
  "save": {
   "enabled": true,
   "every_n_epochs": 100,
   "on_best_rollout_success_rate": true
  },
  "epoch_every_n_steps": 100,
  "rollout": {
   "enabled": true,
   "n": 10,
   "horizon": 400,
   "rate": 250
  },
  "render_video": false
 },
 "train": {
  "data": "/scratch/sselvaraj/projects/Flowmatch/robomimic_data/square/ph/image_v15_clean.hdf5",
  "output_dir": "/scratch/sselvaraj/projects/robomimic-cfm/output/transformer",
  "hdf5_filter_key": "train",
  "hdf5_validation_filter_key": "valid",
  "hdf5_cache_mode": "low_dim",
  "num_data_workers": 4,
  "num_epochs": 1000,
  "batch_size": 64,
  "seed": 3
 },
 "algo": {
  "unet": {
   "enabled": false
  },
  "transformer": {
   "enabled": true,
   "n_emb": 256,
   "n_layer": 8,
   "n_head": 4,
   "p_drop": 0.1,
   "diffusion_step_embed_dim": 256,
   "causal": false
  }
 },
 "observation": {
  "modalities": {
   "obs": {
    "low_dim": [
     "robot0_eef_pos",
     "robot0_eef_quat",
     "robot0_gripper_qpos",
     "object"
    ],
    "rgb": [
     "agentview_image",
     "robot0_eye_in_hand_image"
    ]
   }
  },
  "encoder": {
   "rgb": {
    "core_class": "VisualCore",
    "core_kwargs": {
     "feature_dimension": 64,
     "backbone_class": "ResNet18Conv",
     "backbone_kwargs": {
      "pretrained": false,
      "input_coord_conv": false
     },
     "pool_class": "SpatialSoftmax",
     "pool_kwargs": {
      "num_kp": 32,
      "learnable_temperature": false,
      "temperature": 1.0,
      "noise_std": 0.0,
      "output_variance": false
     }
    },
    "obs_randomizer_class": "CropRandomizer",
    "obs_randomizer_kwargs": {
     "crop_height": 76,
     "crop_width": 76,
     "num_crops": 1,
     "pos_enc": false
    }
   }
  }
 }
}